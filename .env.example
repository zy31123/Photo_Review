# Photo Review 环境变量配置
# 复制此文件为 .env 并按需修改

# === 服务端 ===
# 后端监听端口
PORT=3001

# CORS 允许的源 (逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 缩略图尺寸 (px)
THUMBNAIL_SIZE=400

# 内存缓存条目上限
MAX_MEMORY_CACHE=500

# 磁盘缓存上限 (MB)
MAX_DISK_CACHE_MB=500

# 最近文件夹数量上限
MAX_FOLDERS=10

# 默认分页大小
DEFAULT_PAGE_LIMIT=5000

# === 客户端 ===
# 前端开发服务器端口 (vite.config.ts 读取)
FRONTEND_PORT=5173
