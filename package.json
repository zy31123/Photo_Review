{
  "name": "photo-review",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --raw \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client --silent",
    "dev:server": "npm run dev --workspace=server --silent",
    "build": "npm run build --workspace=client && npm run build --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
