{
  "name": "photo-review",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npx concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "test:photos": "npx tsx e2e/fixtures/generate-test-photos.ts",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed",
    "test:report": "npx tsx e2e/reports/generate-report.ts",
    "test:full": "npm run test:photos && npm run test:e2e && npm run test:report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0"
  }
}
