{
  "name": "photo-review",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --raw \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client --silent",
    "dev:server": "npm run dev --workspace=server --silent",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "test:photos": "npx tsx e2e/fixtures/generate-visual-photos.ts",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config=e2e/playwright.config.ts --headed",
    "screenshot": "npx tsx e2e/screenshot-all.ts",
    "screenshot:close": "npx tsx e2e/screenshot-all.ts --close"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0"
  }
}
