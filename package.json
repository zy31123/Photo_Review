{
  "name": "photo-review",
  "private": true,
  "workspaces": [
    "packages/shared",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently --raw \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --workspace=client --silent",
    "dev:server": "npm run dev --workspace=server --silent",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=client && npm run build --workspace=server",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.1.2"
  }
}
